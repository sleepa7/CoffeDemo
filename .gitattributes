# Auto detect text files and perform LF normalization
* text=auto

# Explicitly treat all web assets as text with LF line endings
*.js text eol=lf
*.mjs text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.tsx text eol=lf
*.ts text eol=lf
*.jsx text eol=lf

# Binary files
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.webp binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.otf binary
